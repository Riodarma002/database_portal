# ============================================================
# CONTOH TEMPLATE SECRETS - SALIN KE secrets.toml
# Untuk Streamlit Cloud: masukkan isi ini di Settings > Secrets
# ============================================================

[database]
host     = "IP_SERVER_ANDA"
port     = 3306
user     = "USERNAME_DB"
password = "PASSWORD_DB"
database = "NAMA_DATABASE"

[auth]
username = "USERNAME_LOGIN"
password = "PASSWORD_LOGIN"
